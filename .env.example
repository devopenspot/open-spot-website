# ---------------------------------------------------------------------------
# Public origin (used by metadataBase, sitemap, robots). Set to your
# production URL on Vercel (e.g. https://openspot.vercel.app).
# ---------------------------------------------------------------------------
APP_URL=https://openspot.example.com

# ---------------------------------------------------------------------------
# OpenWeather (current weather + forecast + icons)
# ---------------------------------------------------------------------------
URL_WEATHER=https://api.openweathermap.org
URL_WEATHER_IMG=https://openweathermap.org/payload/api/media/file
API_KEY_WEATHER=

# Secret required by POST /api/weather/revalidate to bust a single spot's
# cache. Send as `x-revalidate-secret: <value>` header. Any non-empty string.
REVALIDATE_SECRET=

# ---------------------------------------------------------------------------
# Nominatim (OpenStreetMap geocoder, autocomplete, reverse, nearby)
# Required User-Agent per Nominatim Usage Policy: descriptive, with a contact
# channel.
# ---------------------------------------------------------------------------
NOMINATIM_URL=https://nominatim.openstreetmap.org
NOMINATIM_USER_AGENT=open-spot-website/1.0 (contact@example.com)

# ---------------------------------------------------------------------------
# Local Postgres (docker compose up -d infra-db). Used by `pnpm db:health`,
# `pnpm db:seed`, `pnpm db:apply`, `pnpm db:deploy`, and the runtime Drizzle
# client when Supabase is not configured.
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql://dev:dev@localhost:5432/app

# ---------------------------------------------------------------------------
# Supabase (server-only, when SPOTS_DATA_SOURCE=db)
#
# When you wire the app to a Supabase project, set the env vars below in
# BOTH `.env.local` (for `pnpm dev`) and Vercel (for production). See
# DEPLOY.md for the exact Vercel env list and the bucket-creation step.
# ---------------------------------------------------------------------------

# Browser-public. Read by the @supabase/ssr browser client + middleware.
# NEXT_PUBLIC_ prefix is required for the client bundle.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. NEVER prefix with NEXT_PUBLIC_ or expose to the bundle.
# Two names are accepted (same value):
#   SUPABASE_SECRET_KEY             <- the name the code reads first
#   SUPABASE_SERVICE_ROLE_KEY       <- the SPEC §E.4 name (fallback)
SUPABASE_SECRET_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# Direct (non-pooled) Postgres connection. Used by `pnpm db:deploy`,
# `pnpm db:apply`, and any operator SQL. Two names are accepted:
#   SUPABASE_DIRECT_URL     <- the SPEC §E.4 preferred name (read first)
#   DB_CONNETION_STRING     <- the legacy name kept for back-compat
# Port 5432 (direct) — NOT the pgBouncer port 6543.
SUPABASE_DIRECT_URL=
# DB_CONNETION_STRING=

# Pooled Postgres connection. Port 6543. Reserved for the runtime Drizzle
# client on serverless platforms (the current code uses the direct URL for
# simplicity; flip the runtime to use this when the connection load requires
# pgBouncer transaction-mode pooling).
# SUPABASE_DATABASE_URL=

# Storage bucket for user-contributed spot images. Must match the bucket
# created in the Supabase dashboard (see DEPLOY.md step 1). Defaults to
# "spot-images".
# SUPABASE_STORAGE_BUCKET_SPOTS=spot-images

# ---------------------------------------------------------------------------
# Spots data source for the read path (used by the server pages, sitemap,
# /api/spot-types, and the autocomplete / spot-details helpers).
#   "json"  (default) — read directly from src/data/spots.json. No database
#                      required. Use for static deploys or while the DB is
#                      offline.
#   "db"             — read from Postgres via Drizzle (src/db/queries.ts).
#                      Requires DATABASE_URL above (or the Supabase vars)
#                      and a running container.
SPOTS_DATA_SOURCE=json
